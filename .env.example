# ── Local development defaults ──────────────────────────────────────────────
# Copy this file to .env and fill in values as needed.

# Set to "true" to use S3 for cache and used_words storage.
# Leave as "false" (or unset) to use the local filesystem.
USE_S3=false

# Required when USE_S3=true — the name of your S3 bucket.
S3_BUCKET=your-bucket-name-here

# AWS region where the bucket lives (defaults to us-east-2).
AWS_DEFAULT_REGION=us-east-2

# Comma-separated list of allowed CORS origins.
# In production set this to your actual domain or EC2 public DNS, e.g.:
#   ALLOWED_ORIGINS=https://example.com,http://my-ec2-dns.amazonaws.com
# Leave unset (or set to *) during local development.
ALLOWED_ORIGINS=*

# ── OpenAI embedding backend ─────────────────────────────────────────────────
# Set to "true" to use the OpenAI text-embedding-3-small model instead of the
# local BAAI/bge-small-en-v1.5 model.  Requires OPENAI_API_KEY to be set.
USE_OPENAI_EMBEDDING=false
OPENAI_API_KEY=your-openai-api-key-here

# Suppress the HuggingFace symlinks warning on Windows.
HF_HUB_DISABLE_SYMLINKS_WARNING=1
